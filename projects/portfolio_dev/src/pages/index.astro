	<main>
        <section class="w-full lg:w-[740px] mx-auto py-44">
            <h1 class="text-white text-5xl font-bold flex flex-row gap-x-4 pb-10">Hey, soy warj <a href="https://www.linkedin.com/in/william-andres-ramirez-jimenez-b310a0206" target="_blank" rel="noopener"class="flex justify-center items-center"><Badge>Disponible para trabajar</Badge></a></h1>
